{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
"paths": {
      "#/*": ["./src/*"],
      "content-collections": ["./.content-collections/generated"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true, // false
    "allowJs": true,
    "checkJs": false,     // 对 .js 檔案不進行嚴格檢查（避免報錯過多）
    // "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */ 
    "skipLibCheck": true,
    "strict": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    // "noUncheckedIndexedAccess": true     // 额外开启：数组索引访问默认可能 undefined
  }
}
